APP_NAME="Karacabey Gross Market"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://api.karacabeygrossmarket.com
FRONTEND_URL=https://karacabeygrossmarket.com
ADMIN_URL=https://app.karacabeygrossmarket.com
API_URL=https://api.karacabeygrossmarket.com
CORS_ALLOWED_ORIGINS="${FRONTEND_URL},${ADMIN_URL}"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=karacabey_gross_market
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.karacabeygrossmarket.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
NEXT_PUBLIC_API_URL="${API_URL}"

GOOGLE_ANALYTICS_ID=
GOOGLE_ADS_ID=
GOOGLE_ADS_CONVERSION_LABEL=
GOOGLE_SITE_VERIFICATION=
META_PIXEL_ID=

PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
PAYTR_DEBUG=true
PAYTR_CURRENCY=TL
PAYTR_TIMEOUT_LIMIT=30
PAYTR_MAX_INSTALLMENT=0
PAYTR_NO_INSTALLMENT=0
PAYTR_OK_URL="${FRONTEND_URL}/checkout/success"
PAYTR_FAIL_URL="${FRONTEND_URL}/checkout/fail"
